  <script>
    // Smooth Reveal Mechanics via IntersectionObserver
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach((el) => {
      observer.observe(el);
    });

    // Glass Header Adaptive Alpha Shifts
    window.addEventListener('scroll', () => {
      const nav = document.getElementById('navbar');
      if (window.scrollY > 60) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    });

    // Bookmark Toggle Interaction
    function toggleFavorite(button) {
      button.classList.toggle('active');
      const icon = button.querySelector('i');
      if(button.classList.contains('active')) {
        icon.className = "fa-solid fa-heart";
      } else {
        icon.className = "fa-regular fa-heart";
      }
    }

    function togglePaymentOptions(shouldScroll = false) {
      const paymentOptions = document.getElementById('payment-options');
      if (!paymentOptions) return;

      paymentOptions.classList.toggle('active');

      if (shouldScroll) {
        document.getElementById('donate')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    // Theme filters for hero/nav shortcuts
    const filterLabels = {
      all: 'Every swim, trail, show, food stop, museum, day trip, and low-key summer plan from the guide in one place.',
      water: 'Water picks from the Complete 101: swims, floats, pools, lake days, paddles, and splash stops.',
      'live-shows': 'Live-show picks from the Complete 101: concerts, clubs, dance halls, comedy, and open-air stages.',
      'food-trucks': 'Food picks from the Complete 101: trucks, tacos, barbecue, markets, desserts, and casual Austin bites.',
      'hill-country': 'Hill Country picks from the Complete 101: day trips, swimming holes, scenic drives, parks, and small-town stops.'
    };

    const filterKeywords = {
      water: ['water', 'swim', 'pool', 'river', 'lake', 'paddle', 'float', 'springs', 'splash', 'creek', 'falls', 'fountain', 'boat', 'kayak', 'tube', 'cove', 'reservoir'],
      'live-shows': ['concert', 'live music', 'music', 'show', 'amphitheater', 'blues', 'dance hall', 'two-step', 'comedy', 'improv', 'karaoke', 'stage', 'band', 'club'],
      'food-trucks': ['food truck', 'taco', 'breakfast', 'barbecue', 'farmers market', 'dessert', 'ice cream', 'cooking', 'coffee', 'brewery', 'patio', 'scoop', 'paleta'],
      'hill-country': ['hill country', 'day trip', 'dripping springs', 'wimberley', 'fredericksburg', 'new braunfels', 'canyon lake', 'johnson city', 'spicewood', 'lockhart', 'georgetown', 'pedernales', 'hamilton', 'enchanted rock', 'devil', 'scenic drive', 'krause springs', 'pace bend', 'lake travis']
    };

    function filterCompleteGuide(filter) {
      const cards = Array.from(document.querySelectorAll('.thing-card'));
      const summary = document.getElementById('complete-summary');
      const keywords = filterKeywords[filter] || [];
      let visibleCount = 0;

      cards.forEach((card) => {
        const cardText = card.textContent.toLowerCase();
        const shouldShow = filter === 'all' || keywords.some((keyword) => cardText.includes(keyword));
        card.classList.toggle('is-hidden', !shouldShow);
        if (shouldShow) {
          visibleCount += 1;
        }
      });

      if (summary) {
        const baseText = filterLabels[filter] || filterLabels.all;
        summary.textContent = filter === 'all' ? baseText : `${baseText} Showing ${visibleCount} picks.`;
      }

      document.querySelectorAll('[data-filter]').forEach((link) => {
        link.classList.toggle('active', link.dataset.filter === filter);
      });

      document.getElementById('complete-101')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    document.querySelectorAll('[data-filter]').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        filterCompleteGuide(link.dataset.filter || 'all');
      });
    });
  </script>
