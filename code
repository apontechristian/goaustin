<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Austin Summer 2026 | Open Access Guide</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Manrope:wght@500;700;800&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    /* =========================================
       DESIGN SYSTEM & VARIABLES
       ========================================= */
    :root {
      --primary: #0F172A;
      --accent: #F97316;
      --secondary: #38BDF8;
      --highlight: #FDBA74;
      --bg: #FFFDF8;
      --success: #84CC16;
      
      --glass-bg: rgba(255, 255, 255, 0.2);
      --glass-border: rgba(255, 255, 255, 0.3);
      --glass-blur: blur(20px);
      
      --shadow-soft: 0 20px 40px rgba(15, 23, 42, 0.04);
      --shadow-hover: 0 30px 60px rgba(15, 23, 42, 0.08);
      
      --transition-smooth: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      color: var(--primary);
      overflow-x: hidden;
    }

    h1, h2, h3, h4 {
      font-family: 'Manrope', sans-serif;
      letter-spacing: -0.02em;
    }

    /* =========================================
       NAVIGATION (Completely Open Access)
       ========================================= */
    .nav {
      position: fixed;
      top: 0;
      width: 100%;
      padding: 1.5rem 5%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 100;
      background: linear-gradient(to bottom, rgba(15,23,42,0.4) 0%, transparent 100%);
      transition: var(--transition-smooth);
    }

    .nav.scrolled {
      background: rgba(255, 253, 248, 0.85);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border-bottom: 1px solid rgba(15, 23, 42, 0.05);
      padding: 1rem 5%;
    }

    .nav.scrolled .logo, .nav.scrolled .nav-links a {
      color: var(--primary);
    }

    .logo {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 1.5rem;
      color: #fff;
      text-decoration: none;
      letter-spacing: -1px;
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      align-items: center;
    }

    .nav-links a {
      color: #fff;
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      transition: color 0.3s;
    }

    .nav-links a:hover {
      color: var(--highlight);
    }

    .btn-nav-support {
      background: rgba(255,255,255,0.2);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.3);
      padding: 0.6rem 1.25rem;
      border-radius: 50px;
    }

    .nav.scrolled .btn-nav-support {
      background: rgba(15,23,42,0.05);
      border-color: rgba(15,23,42,0.1);
    }

    /* =========================================
       CINEMATIC HERO SECTION
       ========================================= */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 800px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 5%;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
    }

    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, rgba(15,23,42,0.1) 0%, rgba(15,23,42,0.65) 100%);
      z-index: -1;
    }

    .hero-content {
      text-align: center;
      color: #fff;
      max-width: 900px;
    }

    .hero-content h1 {
      font-size: clamp(2.8rem, 5.5vw, 5.5rem);
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      text-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .hero-content p {
      font-size: clamp(1.1rem, 2vw, 1.35rem);
      opacity: 0.95;
      margin-bottom: 3rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }

    /* Search/Discovery Panel */
    .search-panel {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid var(--glass-border);
      border-radius: 100px;
      padding: 0.5rem 0.5rem 0.5rem 1.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 750px;
      margin: 0 auto;
      box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }

    .search-block {
      flex: 1;
      text-align: left;
    }

    .search-block label {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 0.1rem;
      color: rgba(255,255,255,0.8);
    }

    .search-block input {
      background: transparent;
      border: none;
      color: #fff;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      width: 100%;
      outline: none;
    }
    
    .search-block input::placeholder {
      color: rgba(255,255,255,0.5);
    }

    .btn-search {
      background: var(--accent);
      color: #fff;
      border: none;
      height: 52px;
      width: 52px;
      border-radius: 50%;
      font-size: 1.1rem;
      cursor: pointer;
      transition: var(--transition-smooth);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-search:hover {
      background: var(--highlight);
      transform: scale(1.05);
    }

    .category-tags {
      margin-top: 2rem;
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .tag {
      background: rgba(255,255,255,0.12);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15);
      color: #fff;
      padding: 0.5rem 1.25rem;
      border-radius: 50px;
      font-size: 0.85rem;
      text-decoration: none;
      transition: var(--transition-smooth);
    }

    .tag:hover {
      background: #fff;
      color: var(--primary);
      transform: translateY(-2px);
    }

    .tag.active {
      background: #fff;
      color: var(--primary);
      border-color: #fff;
    }

    /* =========================================
       EDITORIAL CONTENT CONFIGURATION
       ========================================= */
    .container {
      max-width: 1500px;
      margin: 0 auto;
      padding: 8rem 5% 4rem;
    }

    .section-header {
      margin-bottom: 4rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .section-header h2 {
      font-size: clamp(2.2rem, 3.5vw, 3.5rem);
      line-height: 1.1;
    }

    .section-header p {
      font-size: 1.05rem;
      color: #64748B;
      margin-top: 0.75rem;
      max-width: 500px;
    }

    /* Asymmetrical Editorial Grid Layout */
    .asym-grid {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 3rem;
      margin-bottom: 6rem;
    }

    .experience-card {
      position: relative;
      background: #fff;
      border-radius: 24px;
      padding: 1.5rem;
      box-shadow: var(--shadow-soft);
      transition: var(--transition-smooth);
      display: flex;
      flex-direction: column;
    }

    .experience-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-hover);
    }

    .card-img-wrapper {
      position: relative;
      width: 100%;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 1.5rem;
    }

    .large-card .card-img-wrapper { aspect-ratio: 4/4.5; }
    .small-card .card-img-wrapper { aspect-ratio: 16/10; }

    .card-img-wrapper img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .experience-card:hover .card-img-wrapper img {
      transform: scale(1.05);
    }

    .badge {
      position: absolute;
      top: 1rem;
      left: 1rem;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(10px);
      color: var(--primary);
      padding: 0.4rem 1rem;
      border-radius: 50px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      z-index: 2;
    }

    .btn-action-round {
      position: absolute;
      top: 1rem;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(10px);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 2;
      transition: var(--transition-smooth);
      color: var(--primary);
    }

    .btn-favorite { right: 4rem; }
    .btn-share { right: 1rem; }

    .btn-action-round:hover {
      background: #fff;
      color: var(--accent);
      transform: scale(1.08);
    }

    /* Active dynamic state for interaction */
    .btn-favorite.active i {
      color: var(--accent);
      font-weight: 900;
    }

    .card-content h3 {
      font-size: 1.65rem;
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .card-content p {
      color: #52525B;
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 1.5rem;
      flex-grow: 1;
    }

    .card-meta {
      display: flex;
      gap: 1.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid #F1F5F9;
      font-size: 0.85rem;
      color: #71717A;
      font-weight: 500;
    }

    .card-meta span i {
      color: var(--accent);
      margin-right: 0.3rem;
    }

    .stacked-cards {
      display: flex;
      flex-direction: column;
      gap: 3rem;
    }
    /* =========================================
       COMPLETE 101 DIRECTORY
       ========================================= */
    .complete-section {
      margin: 3rem 0 6rem;
    }

    .complete-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .thing-card {
      background: #fff;
      border: 1px solid #F1F5F9;
      border-radius: 24px;
      padding: 1.35rem;
      box-shadow: var(--shadow-soft);
      transition: var(--transition-smooth);
      min-height: 260px;
      display: flex;
      flex-direction: column;
    }

    .thing-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-hover);
      border-color: rgba(249, 115, 22, 0.18);
    }

    .thing-card.is-hidden {
      display: none;
    }

    .thing-topline {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1.1rem;
    }

    .thing-number {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(249, 115, 22, 0.1);
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      flex: 0 0 auto;
    }

    .thing-category {
      color: #64748B;
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-align: right;
    }

    .thing-card h3 {
      font-size: 1.25rem;
      line-height: 1.25;
      margin-bottom: 0.65rem;
    }

    .thing-card p {
      color: #52525B;
      font-size: 0.92rem;
      line-height: 1.6;
      margin-bottom: 1.2rem;
      flex-grow: 1;
    }

    .thing-card .card-meta {
      gap: 1rem;
      flex-wrap: wrap;
    }


    /* =========================================
       LUXURY SPOTLIGHT IMAGERY SPREAD
       ========================================= */
    .spotlight {
      position: relative;
      border-radius: 32px;
      overflow: hidden;
      margin: 4rem 0 8rem;
      min-height: 600px;
      display: flex;
      align-items: center;
    }

    .spotlight-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -2;
    }

    .spotlight-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 55%;
      height: 100%;
      background: linear-gradient(90deg, rgba(15,23,42,0.85) 0%, transparent 100%);
      z-index: -1;
    }

    .spotlight-content {
      padding: 5rem;
      max-width: 650px;
      color: #fff;
    }

    .spotlight-content h2 {
      font-size: clamp(2.5rem, 4vw, 4rem);
      line-height: 1.1;
      margin: 1rem 0 1.5rem;
    }

    .spotlight-content p {
      font-size: 1.1rem;
      line-height: 1.6;
      opacity: 0.9;
      margin-bottom: 2.5rem;
    }

    .btn-editorial {
      background: #fff;
      color: var(--primary);
      padding: 0.9rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      text-decoration: none;
      display: inline-block;
      transition: var(--transition-smooth);
    }

    .btn-editorial:hover {
      background: var(--accent);
      color: #fff;
      transform: translateY(-2px);
    }

    /* =========================================
       DONATION SUPPORT HUB (Sunset Gradient)
       ========================================= */
    .support-section {
      background: radial-gradient(circle at 90% 10%, var(--highlight) 0%, transparent 60%),
                  linear-gradient(135deg, rgba(15,23,42,0.03) 0%, rgba(249,131,22,0.06) 100%);
      border: 1px solid rgba(249, 115, 22, 0.1);
      border-radius: 32px;
      padding: 4rem;
      text-align: center;
      max-width: 1000px;
      margin: 4rem auto;
      box-shadow: var(--shadow-soft);
    }

    .support-container {
      max-width: 650px;
      margin: 0 auto;
    }

    .support-section h3 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
      color: var(--primary);
    }

    .support-section p {
      font-size: 1.05rem;
      color: #4B5563;
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    .btn-coffee {
      background: var(--primary);
      color: #fff;
      text-decoration: none;
      padding: 1rem 2.5rem;
      border-radius: 50px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
      transition: var(--transition-smooth);
      border: none;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
    }

    .btn-coffee:hover {
      background: var(--accent);
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(249, 115, 22, 0.25);
    }

    .payment-options {
      display: none;
      margin-top: 2rem;
      text-align: left;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(15, 23, 42, 0.08);
      border-radius: 24px;
      padding: 1.25rem;
      box-shadow: var(--shadow-soft);
    }

    .payment-options.active {
      display: block;
    }

    .payment-note {
      color: #475569;
      font-size: 0.95rem;
      line-height: 1.5;
      margin-bottom: 1rem;
      text-align: center;
    }

    .payment-number {
      color: var(--primary);
      font-family: 'Manrope', sans-serif;
      font-size: 1.45rem;
      font-weight: 800;
      text-align: center;
      margin-bottom: 1.25rem;
      letter-spacing: 0;
    }

    .payment-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 0.85rem;
    }

    .payment-app {
      background: #fff;
      border: 1px solid #F1F5F9;
      border-radius: 18px;
      padding: 1rem 0.75rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      min-height: 118px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
    }

    .payment-logo {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Manrope', sans-serif;
      font-size: 0.95rem;
      font-weight: 800;
      letter-spacing: 0;
    }

    .logo-zelle { background: #6D1ED4; }
    .logo-venmo {
      background: #008CFF;
      font-size: 0.57rem;
      letter-spacing: 0.04em;
    }
    .logo-cashapp { background: #00D632; }
    .logo-paypal { background: #003087; }
    .logo-ath {
      background: #F97316;
      color: #111827;
      font-size: 1rem;
      letter-spacing: 0.02em;
    }

    .payment-app strong {
      color: var(--primary);
      font-size: 0.88rem;
      text-align: center;
    }

    .payment-app small {
      color: #64748B;
      font-size: 0.78rem;
      font-weight: 600;
      text-align: center;
    }

    /* =========================================
       FLOATING CONTEXT SUPPORT ACTION
       ========================================= */
    .floating-support {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: var(--glass-blur);
      -webkit-backdrop-filter: var(--glass-blur);
      border: 1px solid rgba(255,255,255,0.1);
      color: #fff;
      padding: 0.8rem 1.4rem;
      border-radius: 50px;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 600;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      z-index: 90;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      transition: var(--transition-smooth);
    }

    .floating-support:hover {
      background: var(--accent);
      transform: translateY(-4px) scale(1.02);
    }

    /* =========================================
       COMMUNITY DRIVEN FOOTER
       ========================================= */
    .footer {
      border-top: 1px solid #E2E8F0;
      padding: 4rem 5% 5rem;
      text-align: center;
      background-color: #FFFDF8;
    }

    .footer-brand {
      font-family: 'Manrope', sans-serif;
      font-weight: 800;
      font-size: 1.25rem;
      margin-bottom: 1rem;
      letter-spacing: -0.5px;
    }

    .footer-manifesto {
      font-size: 1.05rem;
      color: #475569;
      max-width: 550px;
      margin: 0 auto 1.5rem;
      line-height: 1.5;
    }

    .footer-legal-notes {
      font-size: 0.85rem;
      color: #94A3B8;
      font-weight: 500;
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }

    .footer-craft-mark {
      font-size: 0.95rem;
      color: #64748B;
      font-weight: 500;
    }

    /* Scroll animations */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* =========================================
       RESPONSIVE BREAKPOINTS
       ========================================= */
    @media (max-width: 1024px) {
      .asym-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
      }
      .spotlight-overlay {
        width: 100%;
        background: linear-gradient(0deg, rgba(15,23,42,0.9) 0%, rgba(15,23,42,0.3) 100%);
      }
      .spotlight-content {
        padding: 3rem 2rem;
        margin-top: auto;
      }
      .search-panel {
        flex-direction: column;
        border-radius: 24px;
        padding: 1.5rem;
        gap: 1.25rem;
      }
      .search-block {
        width: 100%;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(255,255,255,0.15);
      }
      .btn-search {
        width: 100%;
        border-radius: 14px;
        height: 48px;
      }
      .support-section {
        padding: 2.5rem 1.5rem;
      }
      .floating-support {
        left: 1rem;
        right: 1rem;
        bottom: 1rem;
        justify-content: center;
        text-align: center;
      }
      .payment-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .payment-app:last-child {
        grid-column: 1 / -1;
      }
      .complete-grid {
        grid-template-columns: 1fr;
      }
      .thing-card {
        min-height: auto;
      }
      .hide-mobile {
        display: none;
      }
    }
  </style>
</head>
<body>

  <a href="#donate" class="floating-support" onclick="togglePaymentOptions(true)">
    <span>☕ Buy me a coffee, Send me a $1</span>
  </a>

  <nav class="nav" id="navbar">
    <a href="#" class="logo">AUSTIN.</a>
    <div class="nav-links">
      <a href="#complete-101" class="hide-mobile" data-filter="all">The Complete 101</a>
      <a href="#complete-101" class="hide-mobile" data-filter="water">Water List</a>
      <a href="#complete-101" class="hide-mobile" data-filter="hill-country">Hill Country Edit</a>
      <a href="#donate" class="btn-nav-support" onclick="togglePaymentOptions(true)">Buy me a coffee</a>
    </div>
  </nav>

  <header class="hero">
    <img src="https://encrypted-tbn0.gstatic.com/licensed-image?q=tbn:ANd9GcQomb6k3jplJttPb9JJlAvGs1XHNDGKoDJZN4yutigJqI4E2uOvDjd2Ep67XzT7Us52BZsOo3Cy6UAFK94" alt="Paddleboarding Austin Summer Background" class="hero-bg">
